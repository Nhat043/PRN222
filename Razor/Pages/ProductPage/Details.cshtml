@page
@model Razor.Pages.ProductPage.DetailsModel

@{
    ViewData["Title"] = "Product Details";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-page="/Index">Home</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a asp-page="/ProductPage/Index">Products</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">Details</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Product Information Card -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-info-circle me-2"></i>Product Details
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (Model.Product != null)
                    {
                        <div class="row">
                            <div class="col-md-4">
                                <div class="text-center mb-4">
                                    @if (!string.IsNullOrEmpty(Model.Product.Picture))
                                    {
                                        <img src="@Model.Product.Picture" alt="@Model.Product.Name" 
                                             class="img-fluid rounded shadow-sm" style="max-height: 300px;" />
                                    }
                                    else
                                    {
                                        <div class="bg-light rounded d-flex align-items-center justify-content-center" 
                                             style="height: 300px;">
                                            <i class="fas fa-image fa-4x text-muted"></i>
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="col-md-8">
                                <div class="d-flex align-items-center mb-4">
                                    <div class="bg-info bg-opacity-10 rounded-circle p-3 me-3">
                                        <i class="fas fa-box fa-2x text-info"></i>
                                    </div>
                                    <div>
                                        <h4 class="mb-1">@Model.Product.Name</h4>
                                        <p class="text-muted mb-0">Product Information</p>
                                    </div>
                                </div>

                                <div class="table-responsive">
                                    <table class="table table-borderless">
                                        <tbody>
                                            <tr>
                                                <td class="fw-semibold text-muted" style="width: 30%;">
                                                    <i class="fas fa-id-badge me-2"></i>Product ID:
                                                </td>
                                                <td class="fw-medium">@Model.Product.Id</td>
                                            </tr>
                                            <tr>
                                                <td class="fw-semibold text-muted">
                                                    <i class="fas fa-box me-2"></i>Product Name:
                                                </td>
                                                <td class="fw-medium">@Model.Product.Name</td>
                                            </tr>
                                            <tr>
                                                <td class="fw-semibold text-muted">
                                                    <i class="fas fa-align-left me-2"></i>Description:
                                                </td>
                                                <td class="fw-medium">@Model.Product.Description</td>
                                            </tr>
                                            <tr>
                                                <td class="fw-semibold text-muted">
                                                    <i class="fas fa-tag me-2"></i>Category:
                                                </td>
                                                <td>
                                                    @if (Model.Product.Category != null)
                                                    {
                                                        <span class="badge bg-primary bg-opacity-10 text-primary" style="min-width: 80px;">
                                                            @Model.Product.Category.Name
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="fw-semibold text-muted">
                                                    <i class="fas fa-circle me-2"></i>Status:
                                                </td>
                                                <td>
                                                    @{
                                                        var statusClass = Model.Product.Status?.Name?.ToLower() switch
                                                        {
                                                            "active" => "bg-success",
                                                            "inactive" => "bg-secondary",
                                                            "draft" => "bg-warning",
                                                            _ => "bg-info"
                                                        };
                                                    }
                                                    @if (Model.Product.Status != null)
                                                    {
                                                        <span class="badge @statusClass" style="min-width: 80px;">
                                                            @Model.Product.Status.Name
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4">

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-page="Index" class="btn btn-outline-secondary me-md-2">
                                <i class="fas fa-arrow-left me-2"></i>Back to List
                            </a>
                            <a asp-page="./Edit" asp-route-id="@Model.Product.Id" class="btn btn-warning">
                                <i class="fas fa-edit me-2"></i>Edit Product
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-exclamation-triangle fa-3x text-warning mb-3"></i>
                            <h5 class="text-muted">Product Not Found</h5>
                            <p class="text-muted">The requested product could not be found.</p>
                            <a asp-page="Index" class="btn btn-primary">
                                <i class="fas fa-arrow-left me-2"></i>Back to Products
                            </a>
                        </div>
                    }
                </div>
            </div>

            <!-- Product Items Section -->
            @if (Model.Product != null)
            {
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <div asp-validation-summary="All" class="mb-0"></div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <div class="card shadow-sm">
                    <div class="card-header bg-success text-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">
                                <i class="fas fa-cubes me-2"></i>Product Items
                            </h5>
                            <button class="btn btn-light btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#addProductItemForm">
                                <i class="fas fa-plus me-2"></i>Add Product Item
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <!-- Add Product Item Form -->
                        <div class="collapse" id="addProductItemForm">
                            <div class="p-4 border-bottom">
                                <form method="post" asp-page-handler="CreateProductItem" asp-route-productId="@Model.Product.Id">
                                    <div class="row">
                                        <div class="col-md-3">
                                            <div class="mb-3">
                                                <label asp-for="NewProductItem.Quantity" class="form-label fw-semibold">
                                                    <i class="fas fa-hashtag me-2"></i>Quantity
                                                </label>
                                                <input asp-for="NewProductItem.Quantity" class="form-control" type="number" min="0" />
                                                <span asp-validation-for="NewProductItem.Quantity" class="text-danger small"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="mb-3">
                                                <label asp-for="NewProductItem.ImportPrice" class="form-label fw-semibold">
                                                    <i class="fas fa-dollar-sign me-2"></i>Import Price
                                                </label>
                                                <input asp-for="NewProductItem.ImportPrice" class="form-control" type="number" min="0" step="100000" />
                                                <span asp-validation-for="NewProductItem.ImportPrice" class="text-danger small"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="mb-3">
                                                <label asp-for="NewProductItem.SellingPrice" class="form-label fw-semibold">
                                                    <i class="fas fa-tag me-2"></i>Selling Price
                                                </label>
                                                <input asp-for="NewProductItem.SellingPrice" class="form-control" type="number" min="0" step="100000" />
                                                <span asp-validation-for="NewProductItem.SellingPrice" class="text-danger small"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="mb-3">
                                                <label asp-for="NewProductItem.Discount" class="form-label fw-semibold">
                                                    <i class="fas fa-percent me-2"></i>Discount
                                                </label>
                                                <input asp-for="NewProductItem.Discount" class="form-control" type="number" min="0" max="100" step="0.01" />
                                                <span asp-validation-for="NewProductItem.Discount" class="text-danger small"></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label class="form-label fw-semibold">
                                                    <i class="fas fa-circle me-2"></i>Status
                                                </label>
                                                <select asp-for="NewProductItem.StatusId" class="form-select">
                                                    <option value="">Select a status...</option>
                                                    @foreach (var status in Model.Statuses)
                                                    {
                                                        <option value="@status.Id">@status.Name</option>
                                                    }
                                                </select>
                                                <span asp-validation-for="NewProductItem.StatusId" class="text-danger small"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label class="form-label fw-semibold">
                                                    <i class="fas fa-cogs me-2"></i>Variation Options
                                                </label>
                                                <div class="border rounded p-3">
                                                    @if (Model.Variations.Any())
                                                    {
                                                        foreach (var variation in Model.Variations)
                                                        {
                                                            <div class="mb-2">
                                                                <label class="form-label small text-muted">@variation.Name</label>
                                                                <select name="SelectedVariationOptionIds[@variation.Name]" class="form-select form-select-sm">
                                                                    <option value="">-- Select @variation.Name --</option>
                                                                    @foreach (var option in variation.VariationOptions)
                                                                    {
                                                                        <option value="@option.Id">@option.Value</option>
                                                                    }
                                                                </select>
                                                            </div>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <p class="text-muted small mb-0">No variation options available.</p>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-end">
                                        <button type="submit" class="btn btn-success">
                                            <i class="fas fa-save me-2"></i>Add Product Item
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>

                        <!-- Edit Product Item Form -->
                        @if (Model.EditingProductItemId.HasValue)
                        {
                            <div class="p-4 border-bottom bg-warning bg-opacity-10">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h6 class="mb-0 text-warning">
                                        <i class="fas fa-edit me-2"></i>Editing Product Item #@Model.EditingProductItemId
                                    </h6>
                                    <a asp-page="" asp-route-id="@Model.Product.Id" class="btn btn-outline-secondary btn-sm">
                                        <i class="fas fa-times me-2"></i>Cancel Edit
                                    </a>
                                </div>
                                <form method="post" asp-page-handler="UpdateProductItem" asp-route-productId="@Model.Product.Id" asp-route-productItemId="@Model.EditingProductItemId">
                                    <div class="row">
                                        <div class="col-md-3">
                                            <div class="mb-3">
                                                <label asp-for="EditingProductItem.Quantity" class="form-label fw-semibold">
                                                    <i class="fas fa-hashtag me-2"></i>Quantity
                                                </label>
                                                <input asp-for="EditingProductItem.Quantity" class="form-control" type="number" min="0" />
                                                <span asp-validation-for="EditingProductItem.Quantity" class="text-danger small"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="mb-3">
                                                <label asp-for="EditingProductItem.ImportPrice" class="form-label fw-semibold">
                                                    <i class="fas fa-dollar-sign me-2"></i>Import Price
                                                </label>
                                                <input asp-for="EditingProductItem.ImportPrice" class="form-control" type="number" min="0" step="100000" />
                                                <span asp-validation-for="EditingProductItem.ImportPrice" class="text-danger small"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="mb-3">
                                                <label asp-for="EditingProductItem.SellingPrice" class="form-label fw-semibold">
                                                    <i class="fas fa-tag me-2"></i>Selling Price
                                                </label>
                                                <input asp-for="EditingProductItem.SellingPrice" class="form-control" type="number" min="0" step="100000" />
                                                <span asp-validation-for="EditingProductItem.SellingPrice" class="text-danger small"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="mb-3">
                                                <label asp-for="EditingProductItem.Discount" class="form-label fw-semibold">
                                                    <i class="fas fa-percent me-2"></i>Discount
                                                </label>
                                                <input asp-for="EditingProductItem.Discount" class="form-control" type="number" min="0" max="100" step="0.01" />
                                                <span asp-validation-for="EditingProductItem.Discount" class="text-danger small"></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label class="form-label fw-semibold">
                                                    <i class="fas fa-circle me-2"></i>Status
                                                </label>
                                                <select asp-for="EditingProductItem.StatusId" class="form-select">
                                                    <option value="">Select a status...</option>
                                                    @foreach (var status in Model.Statuses)
                                                    {
                                                        <option value="@status.Id">@status.Name</option>
                                                    }
                                                </select>
                                                <span asp-validation-for="EditingProductItem.StatusId" class="text-danger small"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label class="form-label fw-semibold">
                                                    <i class="fas fa-cogs me-2"></i>Variation Options
                                                </label>
                                                <div class="border rounded p-3">
                                                    @if (Model.Variations.Any())
                                                    {
                                                        foreach (var variation in Model.Variations)
                                                        {
                                                            <div class="mb-2">
                                                                <label class="form-label small text-muted">@variation.Name</label>
                                                                <select name="EditingVariationOptionIds[@variation.Name]" class="form-select form-select-sm">
                                                                    <option value="">-- Select @variation.Name --</option>
                                                                    @foreach (var option in variation.VariationOptions)
                                                                    {
                                                                        var isSelected = Model.EditingProductItem.VariationOptions.Any(vo => vo.Id == option.Id);
                                                                        <option value="@option.Id" selected="@isSelected">@option.Value</option>
                                                                    }
                                                                </select>
                                                            </div>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <p class="text-muted small mb-0">No variation options available.</p>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-end">
                                        <button type="submit" class="btn btn-warning">
                                            <i class="fas fa-save me-2"></i>Update Product Item
                                        </button>
                                    </div>
                                </form>
                            </div>
                        }

                        <!-- Product Items Table -->
                        @if (Model.ProductItems.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="border-0">
                                                <i class="fas fa-id-badge me-2"></i>ID
                                            </th>
                                            <th class="border-0">
                                                <i class="fas fa-hashtag me-2"></i>Quantity
                                            </th>
                                            <th class="border-0">
                                                <i class="fas fa-dollar-sign me-2"></i>Import Price
                                            </th>
                                            <th class="border-0">
                                                <i class="fas fa-tag me-2"></i>Selling Price
                                            </th>
                                            <th class="border-0">
                                                <i class="fas fa-percent me-2"></i>Discount
                                            </th>
                                            <th class="border-0">
                                                <i class="fas fa-circle me-2"></i>Status
                                            </th>
                                            <th class="border-0">
                                                <i class="fas fa-cogs me-2"></i>Variations
                                            </th>
                                            <th class="border-0 text-end">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.ProductItems)
                                        {
                                            <tr>
                                                <td class="align-middle">@item.Id</td>
                                                <td class="align-middle">@item.Quantity</td>
                                                <td class="align-middle">$@item.ImportPrice?.ToString("N2")</td>
                                                <td class="align-middle">$@item.SellingPrice?.ToString("N2")</td>
                                                <td class="align-middle">@item.Discount?.ToString("N1")%</td>
                                                <td class="align-middle">
                                                    @{
                                                        var itemStatusClass = item.Status?.Name?.ToLower() switch
                                                        {
                                                            "active" => "bg-success",
                                                            "inactive" => "bg-secondary",
                                                            "out_of_stock" => "bg-danger",
                                                            _ => "bg-info"
                                                        };
                                                    }
                                                    <span class="badge @itemStatusClass">
                                                        @item.Status?.Name
                                                    </span>
                                                </td>
                                                <td class="align-middle">
                                                    @{
                                                        var ramOption = item.VariationOptions.FirstOrDefault(vo => vo.Variation?.Name?.ToLower() == "ram");
                                                        var storageOption = item.VariationOptions.FirstOrDefault(vo => vo.Variation?.Name?.ToLower() == "storage");
                                                    }
                                                    <span>
                                                        Ram: @(ramOption != null ? ramOption.Value : "-")<br />
                                                        Storage: @(storageOption != null ? storageOption.Value : "-")
                                                    </span>
                                                </td>
                                                <td class="align-middle text-end">
                                                    <div class="btn-group" role="group">
                                                        <a asp-page="" asp-page-handler="EditProductItem" asp-route-productId="@Model.Product.Id" asp-route-productItemId="@item.Id" 
                                                           class="btn btn-sm btn-outline-warning" title="Edit">
                                                            <i class="fas fa-edit"></i>
                                                        </a>
                                                        <form method="post" asp-page-handler="DeleteProductItem" 
                                                              asp-route-productItemId="@item.Id" asp-route-productId="@Model.Product.Id" 
                                                              style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this product item?');">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="fas fa-cubes fa-3x text-muted mb-3"></i>
                                <h5 class="text-muted">No Product Items Found</h5>
                                <p class="text-muted">This product doesn't have any items yet.</p>
                                <button class="btn btn-success" type="button" data-bs-toggle="collapse" data-bs-target="#addProductItemForm">
                                    <i class="fas fa-plus me-2"></i>Add First Product Item
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .card {
        border: none;
        border-radius: 15px;
    }
    
    .card-header {
        border-radius: 15px 15px 0 0 !important;
    }
    
    .card-header.bg-info {
        background: linear-gradient(135deg, #17a2b8 0%, #138496 100%) !important;
    }
    
    .card-header.bg-success {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%) !important;
    }
    
    .table td {
        padding: 0.75rem 0;
        border: none;
    }
    
    .btn {
        border-radius: 8px;
        padding: 0.75rem 1.5rem;
        font-weight: 500;
        transition: all 0.3s ease;
    }
    
    .btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }
    
    .btn-sm {
        padding: 0.5rem 0.75rem;
    }
    
    .breadcrumb {
        background: none;
        padding: 0;
    }
    
    .breadcrumb-item a {
        color: #667eea;
        text-decoration: none;
    }
    
    .breadcrumb-item.active {
        color: #6c757d;
    }
    
    hr {
        border-color: #e3e6f0;
        opacity: 0.5;
    }
    
    .badge {
        font-size: 0.75rem;
        padding: 0.5rem 0.75rem;
    }
    
    .form-control, .form-select {
        border-radius: 8px;
        border: 2px solid #e3e6f0;
        transition: all 0.3s ease;
    }
    
    .form-control:focus, .form-select:focus {
        border-color: #28a745;
        box-shadow: 0 0 0 0.2rem rgba(40, 167, 69, 0.25);
    }
</style>

@section Scripts {
    <script src="~/microsoft/signalr/dist/browser/signalr.js"></script>
    <script>
        var productId = @Model.Product.Id;
        var connection = new signalR.HubConnectionBuilder()
            .withUrl("/DataSignalRChanel")
            .build();
        connection.start().then(function () {
            // Connected
        }).catch(function (err) {
            console.error("SignalR error: " + err);
        });
        connection.on("ProductQuantityChanged", function (changedProductId) {
            if (changedProductId === productId) {
                location.reload();
            }
        });
    </script>
}
