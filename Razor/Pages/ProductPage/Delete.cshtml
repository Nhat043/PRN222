@page
@model Razor.Pages.ProductPage.DeleteModel

@{
    ViewData["Title"] = "Delete Product";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-page="/Index">Home</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a asp-page="/ProductPage/Index">Products</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">Delete</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-exclamation-triangle me-2"></i>Delete Product
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger" role="alert">
                            <h6 class="alert-heading">
                                <i class="fas fa-exclamation-triangle me-2"></i>Cannot Delete Product
                            </h6>
                            <div asp-validation-summary="All" class="mb-0"></div>
                        </div>
                    }

                    @if (Model.Product != null)
                    {
                        <div class="text-center mb-4">
                            <div class="bg-danger bg-opacity-10 rounded-circle d-inline-flex p-3 mb-3">
                                <i class="fas fa-trash fa-2x text-danger"></i>
                            </div>
                            <h4 class="text-danger mb-2">Are you sure?</h4>
                            <p class="text-muted">This action cannot be undone. The product will be permanently deleted.</p>
                        </div>

                        <div class="alert alert-warning" role="alert">
                            <div class="d-flex">
                                <i class="fas fa-exclamation-triangle me-2 mt-1"></i>
                                <div>
                                    <strong>Warning:</strong> Deleting this product may affect associated orders, comments, and product items.
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="text-center mb-4">
                                    @if (!string.IsNullOrEmpty(Model.Product.Picture))
                                    {
                                        <img src="@Model.Product.Picture" alt="@Model.Product.Name" 
                                             class="img-fluid rounded border" style="max-height: 200px;" />
                                    }
                                    else
                                    {
                                        <div class="bg-light rounded d-flex align-items-center justify-content-center" 
                                             style="height: 200px;">
                                            <i class="fas fa-image fa-3x text-muted"></i>
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="col-md-8">
                                <div class="card bg-light">
                                    <div class="card-body">
                                        <h6 class="card-title text-muted mb-3">
                                            <i class="fas fa-info-circle me-2"></i>Product Information
                                        </h6>
                                        <div class="row">
                                            <div class="col-sm-4 fw-semibold text-muted">Product ID:</div>
                                            <div class="col-sm-8">@Model.Product.Id</div>
                                        </div>
                                        <div class="row">
                                            <div class="col-sm-4 fw-semibold text-muted">Product Name:</div>
                                            <div class="col-sm-8">@Model.Product.Name</div>
                                        </div>
                                        <div class="row">
                                            <div class="col-sm-4 fw-semibold text-muted">Category:</div>
                                            <div class="col-sm-8">
                                                <span class="badge bg-primary bg-opacity-10 text-primary">
                                                    @Model.Product.Category?.Name
                                                </span>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-sm-4 fw-semibold text-muted">Status:</div>
                                            <div class="col-sm-8">
                                                @{
                                                    var statusClass = Model.Product.Status?.Name?.ToLower() switch
                                                    {
                                                        "active" => "bg-success",
                                                        "inactive" => "bg-secondary",
                                                        "draft" => "bg-warning",
                                                        _ => "bg-info"
                                                    };
                                                }
                                                <span class="badge @statusClass">
                                                    @Model.Product.Status?.Name
                                                </span>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-sm-4 fw-semibold text-muted">Description:</div>
                                            <div class="col-sm-8">@Model.Product.Description</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <form method="post">
                            <input type="hidden" asp-for="Product.Id" />
                            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                <a asp-page="Index" class="btn btn-outline-secondary me-md-2">
                                    <i class="fas fa-arrow-left me-2"></i>Cancel
                                </a>
                                <button type="submit" class="btn btn-danger">
                                    <i class="fas fa-trash me-2"></i>Delete Product
                                </button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-exclamation-triangle fa-3x text-warning mb-3"></i>
                            <h5 class="text-muted">Product Not Found</h5>
                            <p class="text-muted">The requested product could not be found.</p>
                            <a asp-page="Index" class="btn btn-primary">
                                <i class="fas fa-arrow-left me-2"></i>Back to Products
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border: none;
        border-radius: 15px;
    }
    
    .card.border-danger {
        border: 2px solid #dc3545 !important;
    }
    
    .card-header {
        border-radius: 15px 15px 0 0 !important;
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%) !important;
    }
    
    .btn {
        border-radius: 8px;
        padding: 0.75rem 1.5rem;
        font-weight: 500;
        transition: all 0.3s ease;
    }
    
    .btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }
    
    .breadcrumb {
        background: none;
        padding: 0;
    }
    
    .breadcrumb-item a {
        color: #667eea;
        text-decoration: none;
    }
    
    .breadcrumb-item.active {
        color: #6c757d;
    }
    
    .alert {
        border-radius: 8px;
        border: none;
    }
    
    .card.bg-light {
        border-radius: 8px;
        border: 1px solid #e3e6f0;
    }
    
    .badge {
        font-size: 0.75rem;
        padding: 0.5rem 0.75rem;
    }
</style>
