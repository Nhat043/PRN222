@page
@model Razor.Pages.ProductItemPage.IndexModel

@{
    ViewData["Title"] = "Product Items";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header bg-success text-white">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="mb-0">
                    <i class="fas fa-boxes"></i> Product Items
                </h4>
                <div>
                    <a asp-page="Create" class="btn btn-light btn-sm">
                        <i class="fas fa-plus"></i> Add Product Item
                    </a>
                    <a asp-page="Cleanup" class="btn btn-warning btn-sm ms-2">
                        <i class="fas fa-broom"></i> Cleanup Duplicates
                    </a>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Product</th>
                            <th>Quantity</th>
                            <th>Import Price</th>
                            <th>Selling Price</th>
                            <th>Discount</th>
                            <th>Status</th>
                            <th>Variations</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.ProductItem) {
                        <tr>
                            <td><span class="badge bg-secondary">@item.Id</span></td>
                            <td>
                                <strong>@item.Product?.Name</strong>
                            </td>
                            <td>
                                <span class="badge bg-info">@item.Quantity</span>
                            </td>
                            <td>
                                <span class="text-success fw-bold">$@item.ImportPrice?.ToString("N0")</span>
                            </td>
                            <td>
                                <span class="text-primary fw-bold">$@item.SellingPrice?.ToString("N0")</span>
                            </td>
                            <td>
                                @if (item.Discount > 0)
                                {
                                    <span class="badge bg-danger">@item.Discount%</span>
                                }
                                else
                                {
                                    <span class="text-muted">0%</span>
                                }
                            </td>
                            <td>
                                @if (item.Status?.Name?.ToLower() == "active")
                                {
                                    <span class="badge bg-success">@item.Status.Name</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Status?.Name</span>
                                }
                            </td>
                            <td>
                                @if (item.VariationOptions != null && item.VariationOptions.Any())
                                {
                                    var groupedOptions = item.VariationOptions
                                        .GroupBy(vo => vo.Variation?.Name ?? "Unknown")
                                        .ToList();
                                    
                                    foreach (var group in groupedOptions)
                                    {
                                        <div class="small">
                                            <strong class="text-primary">@group.Key:</strong>
                                            <span class="ms-1">
                                                @string.Join(", ", group.Select(vo => vo.Value))
                                            </span>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted small">None</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-warning" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-info" title="Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-danger" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
