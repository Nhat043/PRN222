@page
@model Razor.Pages.ProductItemPage.CreateModel

@{
    ViewData["Title"] = "Create Product Item";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-page="/Index">Home</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a asp-page="/ProductItemPage/Index">Product Items</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">Create</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10 col-md-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-plus me-2"></i>Create New Product Item
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-4">
                                    <label asp-for="ProductItem.ProductId" class="form-label fw-semibold">
                                        <i class="fas fa-box me-2"></i>Product <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="ProductItem.ProductId" class="form-select form-select-lg" asp-items="ViewBag.ProductId" required>
                                        <option value="">Select a product...</option>
                                    </select>
                                    <span asp-validation-for="ProductItem.ProductId" class="text-danger small"></span>
                                </div>

                                <div class="mb-4">
                                    <label asp-for="ProductItem.Quantity" class="form-label fw-semibold">
                                        <i class="fas fa-layer-group me-2"></i>Quantity <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="ProductItem.Quantity" class="form-control form-control-lg" 
                                           type="number" min="0" value="0" required />
                                    <span asp-validation-for="ProductItem.Quantity" class="text-danger small"></span>
                                </div>

                                <div class="mb-4">
                                    <label asp-for="ProductItem.ImportPrice" class="form-label fw-semibold">
                                        <i class="fas fa-dollar-sign me-2"></i>Import Price <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text">$</span>
                                        <input asp-for="ProductItem.ImportPrice" class="form-control form-control-lg" 
                                               type="number" min="0" value="0" required />
                                    </div>
                                    <span asp-validation-for="ProductItem.ImportPrice" class="text-danger small"></span>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="mb-4">
                                    <label asp-for="ProductItem.SellingPrice" class="form-label fw-semibold">
                                        <i class="fas fa-tag me-2"></i>Selling Price <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text">$</span>
                                        <input asp-for="ProductItem.SellingPrice" class="form-control form-control-lg" 
                                               type="number" min="0" value="0" required />
                                    </div>
                                    <span asp-validation-for="ProductItem.SellingPrice" class="text-danger small"></span>
                                </div>

                                <div class="mb-4">
                                    <label asp-for="ProductItem.Discount" class="form-label fw-semibold">
                                        <i class="fas fa-percent me-2"></i>Discount (%)
                                    </label>
                                    <div class="input-group">
                                        <input asp-for="ProductItem.Discount" class="form-control form-control-lg" 
                                               type="number" min="0" max="100" step="0.01" value="0" />
                                        <span class="input-group-text">%</span>
                                    </div>
                                    <span asp-validation-for="ProductItem.Discount" class="text-danger small"></span>
                                </div>

                                <div class="alert alert-info">
                                    <i class="fas fa-info-circle me-2"></i>
                                    <strong>Note:</strong> New product items will be set to "Active" status by default.
                                </div>
                            </div>
                        </div>

                        <!-- Variation Options Section -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                <i class="fas fa-cogs me-2"></i>Variation Options
                            </label>
                            <div class="border rounded p-4 bg-light">
                                @if (ViewData["VariationsWithOptions"] != null)
                                {
                                    var variationsWithOptions = (dynamic)ViewData["VariationsWithOptions"];
                                    foreach (var variation in variationsWithOptions)
                                    {
                                        <div class="mb-3">
                                            <label class="form-label text-primary fw-bold">
                                                <i class="fas fa-chevron-right me-2"></i>@variation.VariationName
                                            </label>
                                            <select name="SelectedVariationOptionIds[@variation.VariationName]" class="form-select">
                                                <option value="">-- Select @variation.VariationName --</option>
                                                @foreach (var option in variation.Options)
                                                {
                                                    <option value="@option.Id">@option.Value</option>
                                                }
                                            </select>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="text-center text-muted py-3">
                                        <i class="fas fa-info-circle fa-2x mb-2"></i>
                                        <p>No variation options available.</p>
                                    </div>
                                }
                            </div>
                        </div>

                        <hr class="my-4">

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-page="Index" class="btn btn-outline-secondary me-md-2">
                                <i class="fas fa-arrow-left me-2"></i>Back to List
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Create Product Item
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border: none;
        border-radius: 15px;
    }
    
    .card-header {
        border-radius: 15px 15px 0 0 !important;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
    }
    
    .form-control, .form-select {
        border-radius: 8px;
        border: 2px solid #e3e6f0;
        transition: all 0.3s ease;
    }
    
    .form-control:focus, .form-select:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
    }
    
    .input-group-text {
        border-radius: 8px 0 0 8px;
        border: 2px solid #e3e6f0;
        background-color: #f8f9fa;
    }
    
    .input-group .form-control {
        border-left: none;
        border-radius: 0 8px 8px 0;
    }
    
    .btn {
        border-radius: 8px;
        padding: 0.75rem 1.5rem;
        font-weight: 500;
        transition: all 0.3s ease;
    }
    
    .btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }
    
    .breadcrumb {
        background: none;
        padding: 0;
    }
    
    .breadcrumb-item a {
        color: #667eea;
        text-decoration: none;
    }
    
    .breadcrumb-item.active {
        color: #6c757d;
    }
    
    hr {
        border-color: #e3e6f0;
        opacity: 0.5;
    }
    
    .bg-light {
        background-color: #f8f9fa !important;
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
