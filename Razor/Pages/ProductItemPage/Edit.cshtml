@page
@model Razor.Pages.ProductItemPage.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>ProductItem</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ProductItem.Id" />
            <div class="form-group">
                <label asp-for="ProductItem.ProductId" class="control-label"></label>
                <select asp-for="ProductItem.ProductId" class="form-control" asp-items="ViewBag.ProductId"></select>
                <span asp-validation-for="ProductItem.ProductId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProductItem.Quantity" class="control-label"></label>
                <input asp-for="ProductItem.Quantity" class="form-control" />
                <span asp-validation-for="ProductItem.Quantity" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProductItem.ImportPrice" class="control-label"></label>
                <input asp-for="ProductItem.ImportPrice" class="form-control" />
                <span asp-validation-for="ProductItem.ImportPrice" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProductItem.SellingPrice" class="control-label"></label>
                <input asp-for="ProductItem.SellingPrice" class="form-control" />
                <span asp-validation-for="ProductItem.SellingPrice" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProductItem.Discount" class="control-label"></label>
                <input asp-for="ProductItem.Discount" class="form-control" />
                <span asp-validation-for="ProductItem.Discount" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProductItem.StatusId" class="control-label"></label>
                <select asp-for="ProductItem.StatusId" class="form-control" asp-items="ViewBag.StatusId"></select>
                <span asp-validation-for="ProductItem.StatusId" class="text-danger"></span>
            </div>
            
            <!-- Variation Options Section -->
            <div class="form-group">
                <label class="control-label">Variation Options</label>
                <div class="border p-3 rounded">
                    @if (ViewData["VariationsWithOptions"] != null)
                    {
                        var variationsWithOptions = (dynamic)ViewData["VariationsWithOptions"];
                        foreach (var variation in variationsWithOptions)
                        {
                            var selectedValue = Model.SelectedVariationOptionIds.ContainsKey(variation.VariationName) 
                                ? Model.SelectedVariationOptionIds[variation.VariationName].ToString() 
                                : "";
                            
                            <div class="mb-3">
                                <label class="form-label text-primary fw-bold">@variation.VariationName</label>
                                <select name="SelectedVariationOptionIds[@variation.VariationName]" class="form-control">
                                    <option value="">-- Select @variation.VariationName --</option>
                                    @foreach (var option in variation.Options)
                                    {
                                        if (selectedValue == option.Id.ToString())
                                        {
                                            <option value="@option.Id" selected>@option.Value</option>
                                        }
                                        else
                                        {
                                            <option value="@option.Id">@option.Value</option>
                                        }
                                    }
                                </select>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">No variation options available.</p>
                    }
                </div>
            </div>
            
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
