@page
@model Razor.Pages.VariationOptionPage.CreateModel

@{
    ViewData["Title"] = "Create Variation Option";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="card shadow-sm p-4" style="max-width: 420px; width: 100%; border-radius: 18px;">
        <h2 class="mb-2 text-center">Create</h2>
        <h4 class="mb-4 text-center text-muted">Variation Option</h4>
        <hr />
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="VariationOption.VariationId" class="form-label fw-semibold">Variation</label>
                <select asp-for="VariationOption.VariationId" class="form-control" asp-items="ViewBag.VariationId"></select>
                <span asp-validation-for="VariationOption.VariationId" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="VariationOption.Value" class="form-label fw-semibold">Value</label>
                <input asp-for="VariationOption.Value" class="form-control" />
                <span asp-validation-for="VariationOption.Value" class="text-danger small"></span>
            </div>
            <div class="d-grid mb-2">
                <button type="submit" class="btn btn-primary btn-lg">Create</button>
            </div>
            <div class="text-center">
                <a asp-page="Index" class="text-decoration-underline">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
