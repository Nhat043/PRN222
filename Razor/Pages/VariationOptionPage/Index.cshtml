@page
@model Razor.Pages.VariationOptionPage.IndexModel

@{
    ViewData["Title"] = "Variation Options";
}

<h1 class="mb-4">Variation Options</h1>
<p>
    <a asp-page="Create" class="btn btn-primary mb-3"><i class="fas fa-plus me-1"></i> Create New</a>
</p>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-primary bg-opacity-10 border-0">
                <h4 class="mb-0 text-primary"><i class="fas fa-memory me-2"></i>RAM Options</h4>
            </div>
            <div class="card-body">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th style="width: 60%">Value</th>
                            <th style="width: 40%" class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.RamOptions) {
                        <tr>
                            <td>
                                <span class="badge bg-primary bg-opacity-25 text-primary fs-6 px-3 py-2">@item.Value</span>
                            </td>
                            <td class="text-end">
                                
                                <form method="post" asp-page="Delete" asp-route-id="@item.Id" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" onclick="return confirm('Are you sure you want to delete this RAM option?');">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-info bg-opacity-10 border-0">
                <h4 class="mb-0 text-info"><i class="fas fa-hdd me-2"></i>Storage Options</h4>
            </div>
            <div class="card-body">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th style="width: 60%">Value</th>
                            <th style="width: 40%" class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.StorageOptions) {
                        <tr>
                            <td>
                                <span class="badge bg-info bg-opacity-25 text-info fs-6 px-3 py-2">@item.Value</span>
                            </td>
                            <td class="text-end">
                                <form method="post" asp-page="Delete" asp-route-id="@item.Id" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" onclick="return confirm('Are you sure you want to delete this Storage option?');">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
.card {
    border-radius: 18px;
    border: none;
}
.card-header {
    border-radius: 18px 18px 0 0 !important;
    background: none;
}
.badge {
    font-size: 1.1rem;
    font-weight: 500;
    border-radius: 8px;
}
.btn-outline-danger {
    border-radius: 8px;
}
</style>
