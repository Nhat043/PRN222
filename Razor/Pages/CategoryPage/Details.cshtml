@page
@model Razor.Pages.CategoryPage.DetailsModel

@{
    ViewData["Title"] = "Category Details";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-page="/Index">Home</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a asp-page="/CategoryPage/Index">Categories</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">Details</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-info-circle me-2"></i>Category Details
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (Model.Category != null)
                    {
                        <div class="row">
                            <div class="col-12">
                                <div class="d-flex align-items-center mb-4">
                                    <div class="bg-info bg-opacity-10 rounded-circle p-3 me-3">
                                        <i class="fas fa-tag fa-2x text-info"></i>
                                    </div>
                                    <div>
                                        <h4 class="mb-1">@Model.Category.Name</h4>
                                        <p class="text-muted mb-0">Category Information</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12">
                                <div class="table-responsive">
                                    <table class="table table-borderless">
                                        <tbody>
                                            <tr>
                                                <td class="fw-semibold text-muted" style="width: 30%;">
                                                    <i class="fas fa-id-badge me-2"></i>Category ID:
                                                </td>
                                                <td class="fw-medium">@Model.Category.Id</td>
                                            </tr>
                                            <tr>
                                                <td class="fw-semibold text-muted">
                                                    <i class="fas fa-tag me-2"></i>Category Name:
                                                </td>
                                                <td class="fw-medium">@Model.Category.Name</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4">

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-page="Index" class="btn btn-outline-secondary me-md-2">
                                <i class="fas fa-arrow-left me-2"></i>Back to List
                            </a>
                            <a asp-page="./Edit" asp-route-id="@Model.Category.Id" class="btn btn-warning">
                                <i class="fas fa-edit me-2"></i>Edit Category
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-exclamation-triangle fa-3x text-warning mb-3"></i>
                            <h5 class="text-muted">Category Not Found</h5>
                            <p class="text-muted">The requested category could not be found.</p>
                            <a asp-page="Index" class="btn btn-primary">
                                <i class="fas fa-arrow-left me-2"></i>Back to Categories
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border: none;
        border-radius: 15px;
    }
    
    .card-header {
        border-radius: 15px 15px 0 0 !important;
        background: linear-gradient(135deg, #17a2b8 0%, #138496 100%) !important;
    }
    
    .table td {
        padding: 0.75rem 0;
        border: none;
    }
    
    .btn {
        border-radius: 8px;
        padding: 0.75rem 1.5rem;
        font-weight: 500;
        transition: all 0.3s ease;
    }
    
    .btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }
    
    .breadcrumb {
        background: none;
        padding: 0;
    }
    
    .breadcrumb-item a {
        color: #667eea;
        text-decoration: none;
    }
    
    .breadcrumb-item.active {
        color: #6c757d;
    }
    
    hr {
        border-color: #e3e6f0;
        opacity: 0.5;
    }
</style>
