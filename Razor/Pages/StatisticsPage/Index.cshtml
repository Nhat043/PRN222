@page
@model Razor.Pages.StatisticsPage.IndexModel
@{
    ViewData["Title"] = "Statistics";
}

<div class="card mb-4">
    <div class="card-header bg-primary text-white">
        <i class="fas fa-chart-bar me-2"></i> Statistics Dashboard
    </div>
    <div class="card-body">
        <!-- Filter Section -->
        <div class="row mb-4">
            <div class="col-12">
                <form method="get" class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label asp-for="StartDate" class="form-label">Start Date</label>
                        <input asp-for="StartDate" type="date" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="EndDate" class="form-label">End Date</label>
                        <input asp-for="EndDate" type="date" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-filter me-2"></i>Apply Filter
                        </button>
                        <a href="@Url.Page("/StatisticsPage/Index")" class="btn btn-outline-secondary ms-2">
                            <i class="fas fa-undo me-2"></i>Reset
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <!-- Charts Section -->
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="fas fa-dollar-sign me-2"></i>Revenue Over Time
                    </div>
                    <div class="card-body">
                        <canvas id="revenueChart"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="fas fa-shopping-cart me-2"></i>Orders Per Month
                    </div>
                    <div class="card-body">
                        <canvas id="ordersChart"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="fas fa-star me-2"></i>Best-Selling Products
                    </div>
                    <div class="card-body">
                        <canvas id="bestProductsChart"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="fas fa-chart-line me-2"></i>Average Order Value
                    </div>
                    <div class="card-body">
                        <canvas id="aovChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Chart data will be injected here from the backend
        const revenueData = @Html.Raw(Model.RevenueChartJson);
        const ordersData = @Html.Raw(Model.OrdersChartJson);
        const bestProductsData = @Html.Raw(Model.BestProductsChartJson);
        const aovData = @Html.Raw(Model.AovChartJson);

        // Revenue Chart
        new Chart(document.getElementById('revenueChart'), revenueData);
        // Orders Per Month Chart
        new Chart(document.getElementById('ordersChart'), ordersData);
        // Best-Selling Products Chart
        new Chart(document.getElementById('bestProductsChart'), bestProductsData);
        // Average Order Value Chart
        new Chart(document.getElementById('aovChart'), aovData);
    </script>
} 