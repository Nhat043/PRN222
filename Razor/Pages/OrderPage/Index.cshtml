@page
@model Razor.Pages.OrderPage.IndexModel

<h2>Order List</h2>
<table class="table">
    <thead>
        <tr>
            <th>Order ID</th>
            <th>Placed By</th>
            <th>Order Date</th>
            <th>Total Price</th>
            <th>Status</th>
            <th>Action</th>
            <th>Details</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model.Orders)
        {
            <tr>
                <td>@order.Id</td>
                <td>@(order.User?.Name ?? order.User?.Email ?? "Unknown")</td>

                <td>@order.Date.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@order.Price.ToString("n0") đ</td>
                <td>@order.Status?.Name</td>

                <td colspan="2">
                    <form method="post" asp-page-handler="UpdateStatus">
                        <input type="hidden" name="orderId" value="@order.Id" />
                        <select name="statusId">
                            <option value="1" selected="@(order.StatusId == 1)">Pending</option>
                            <option value="2" selected="@(order.StatusId == 2)">Approved</option>
                            <option value="3" selected="@(order.StatusId == 3)">Rejected</option>
                        </select>
                        <button type="submit">Save</button>
                    </form>
                </td>

                <td>
                    <a asp-page="/OrderPage/Details" asp-route-id="@order.Id">View</a>
                </td>
            </tr>
        }
    </tbody>
</table>
