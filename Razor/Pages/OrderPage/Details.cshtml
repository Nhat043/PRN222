@page "{id:int}"
@model Razor.Pages.OrderPage.DetailsModel

<h2>Order Details</h2>

<table class="table">
    <tr><th>Order ID:</th><td>@Model.Order.Id</td></tr>
    <tr>
        <th>Placed By:</th>
        <td>@(Model.Order.User?.Name ?? Model.Order.User?.Email ?? "Unknown User")</td>
    </tr>

    <tr><th>Order Date:</th><td>@Model.Order.Date.ToString("dd/MM/yyyy HH:mm")</td></tr>
    <tr><th>Total Price:</th><td>@Model.Order.Price.ToString("n0") đ</td></tr>
    <tr>
        <th>Status:</th>
        <td>@Model.Order.Status?.Name</td>
    </tr>
</table>

<h4>Products in Order</h4>
@if (Model.Order.OrderItems.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Product</th>
                <th>Image</th>
                <th>Quantity</th>
                <th>Price</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Order.OrderItems)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.ProductItem?.Product?.Name</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ProductItem?.Product?.Picture))
                        {
                            <img src="@item.ProductItem.Product.Picture" alt="Product image" style="width: 100px;" />
                        }
                        else
                        {
                            <span>No image available</span>
                        }
                    </td>
                    <td>@item.Quantity</td>
                    <td>@item.Price.ToString("n0") đ</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No products in this order.</p>
}
