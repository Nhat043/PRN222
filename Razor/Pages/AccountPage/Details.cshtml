@page
@model Razor.Pages_AccountPage.DetailsModel
@{
    ViewData["Title"] = "Account Details";
    Layout = "../Shared/_Layout.cshtml";
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i>@Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="card shadow-lg p-4" style="min-width: 400px; max-width: 500px; width: 100%;">
        <h3 class="mb-4 text-center"><i class="fas fa-user text-info me-2"></i> Account Details</h3>
        <dl class="row mb-0">
            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.Account.Email</dd>
            <dt class="col-sm-4">Password</dt>
            <dd class="col-sm-8"><span class="text-muted">••••••••</span></dd>
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.Account.Name</dd>
            <dt class="col-sm-4">Phone</dt>
            <dd class="col-sm-8">@Model.Account.Phone</dd>
            <dt class="col-sm-4">Address</dt>
            <dd class="col-sm-8">@Model.Account.Address</dd>
            <dt class="col-sm-4">Role</dt>
            <dd class="col-sm-8">
                @if (Model.Account.Role != null)
                {
                    <span class="badge bg-info text-dark"><i class="fas fa-user-tag me-1"></i> @Model.Account.Role.Name</span>
                }
            </dd>
            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">
                @if (Model.Account.Status != null)
                {
                    <span class="badge bg-@(Model.Account.StatusId == 1 ? "success" : "secondary")">@Model.Account.Status.Name</span>
                }
            </dd>
        </dl>
        <div class="mt-4 text-center">
            @if (Model.Account.StatusId == 1 && Model.Account.RoleId != 1) @* Only show ban button for non-admin active accounts *@
            {
                <form method="post" asp-page-handler="Ban" asp-route-id="@Model.Account.Id" class="d-inline">
                    <button type="submit" class="btn btn-danger me-2" data-bs-toggle="tooltip" data-bs-placement="top" title="Ban"
                            onclick="return confirm('Are you sure you want to ban this account?')">
                        <i class="fas fa-user-slash me-1"></i> Ban
                    </button>
                </form>
            }
            else if (Model.Account.StatusId == 2)
            {
                <form method="post" asp-page-handler="Unban" asp-route-id="@Model.Account.Id" class="d-inline">
                    <button type="submit" class="btn btn-success me-2" data-bs-toggle="tooltip" data-bs-placement="top" title="Unban">
                        <i class="fas fa-user-check me-1"></i> Unban
                    </button>
                </form>
            }
            @if (Model.Account.RoleId == 1)
            {
                <div class="alert alert-warning mt-2" role="alert">
                    <i class="fas fa-shield-alt me-2"></i>This is an admin account and cannot be banned.
                </div>
            }
            <a asp-page="./Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i> Back to List</a>
        </div>
    </div>
</div>

<!-- Order History Section -->
<div class="container mt-5">
    <h4 class="mb-3"><i class="fas fa-history me-2"></i>Order History</h4>
    @if (Model.OrderHistory != null && Model.OrderHistory.Count > 0)
    {
        <table class="table table-bordered table-hover">
            <thead class="table-light">
                <tr>
                    <th>Order ID</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Price</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var order in Model.OrderHistory)
            {
                <tr>
                    <td>@order.Id</td>
                    <td>@order.Date.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@order.Status?.Name</td>
                    <td>@order.Price.ToString("N0")</td>
                    <td>
                        <a asp-page="/OrderPage/Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">
                            <i class="fas fa-eye"></i> See Details
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        <nav aria-label="Order history pagination">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.OrderHistory.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" asp-route-id="@Model.Account.Id" asp-route-pageIndex="@(Model.OrderHistory.PageIndex - 1)" aria-label="Previous">
                        <span aria-hidden="true">&laquo;</span>
                    </a>
                </li>
                @for (int i = 1; i <= Model.OrderHistory.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.OrderHistory.PageIndex ? "active" : "")">
                        <a class="page-link" asp-route-id="@Model.Account.Id" asp-route-pageIndex="@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.OrderHistory.HasNextPage ? "" : "disabled")">
                    <a class="page-link" asp-route-id="@Model.Account.Id" asp-route-pageIndex="@(Model.OrderHistory.PageIndex + 1)" aria-label="Next">
                        <span aria-hidden="true">&raquo;</span>
                    </a>
                </li>
            </ul>
        </nav>
    }
    else
    {
        <div class="alert alert-info">No order history found for this user.</div>
    }
</div>
@section Scripts {
    <script>
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });
    </script>
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
