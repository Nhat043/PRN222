@page
@model Razor.Pages_AccountPage.CreateModel
@{
    ViewData["Title"] = "Create Account";
    Layout = "../Shared/_Layout.cshtml";
}
<div class="d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="card shadow-lg p-4" style="min-width: 400px; max-width: 500px; width: 100%;">
        <h3 class="mb-4 text-center"><i class="fas fa-user-plus text-success me-2"></i> Create Account</h3>
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="form-floating mb-3">
                <input asp-for="Account.Email" class="form-control" placeholder="Email" />
                <label asp-for="Account.Email"></label>
                <span asp-validation-for="Account.Email" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Account.Password" class="form-control" placeholder="Password" type="password" />
                <label asp-for="Account.Password"></label>
                <span asp-validation-for="Account.Password" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Account.Name" class="form-control" placeholder="Name" />
                <label asp-for="Account.Name"></label>
                <span asp-validation-for="Account.Name" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Account.Phone" class="form-control" placeholder="Phone" />
                <label asp-for="Account.Phone"></label>
                <span asp-validation-for="Account.Phone" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Account.Address" class="form-control" placeholder="Address" />
                <label asp-for="Account.Address"></label>
                <span asp-validation-for="Account.Address" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Account.RoleId" class="form-label"></label>
                <select asp-for="Account.RoleId" class="form-select" asp-items="ViewBag.RoleId"></select>
            </div>
            <div class="mb-3">
                <label asp-for="Account.StatusId" class="form-label"></label>
                <select asp-for="Account.StatusId" class="form-select" asp-items="ViewBag.StatusId"></select>
            </div>
            <div class="d-grid">
                <button type="submit" class="btn btn-success"><i class="fas fa-plus me-1"></i> Create</button>
            </div>
        </form>
        <div class="mt-3 text-center">
            <a asp-page="Index" class="text-decoration-none"><i class="fas fa-arrow-left me-1"></i> Back to List</a>
        </div>
    </div>
</div>
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
