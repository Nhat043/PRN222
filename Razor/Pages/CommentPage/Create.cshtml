@page
@model Razor.Pages.CommentPage.CreateModel

@{
    ViewData["Title"] = "Create Comment";
    var isReply = Model.IsReplyMode;
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-page="/Index">Home</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a asp-page="/CommentPage/Index">Comments</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">Create</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-plus me-2"></i>
                        @(isReply ? "Reply to Comment" : "Create New Comment")
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="row">
                            @if (!isReply)
                            {
                                <div class="col-md-6">
                                    <div class="mb-4">
                                        <label class="form-label fw-semibold">
                                            <i class="fas fa-user me-2"></i>User
                                        </label>
                                        <select asp-for="Comment.UserId" class="form-select form-select-lg" asp-items="ViewBag.UserId">
                                            <option value="">Select a user...</option>
                                        </select>
                                        <span asp-validation-for="Comment.UserId" class="text-danger small"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-4">
                                        <label class="form-label fw-semibold">
                                            <i class="fas fa-box me-2"></i>Product
                                        </label>
                                        <select asp-for="Comment.ProductId" class="form-select form-select-lg" asp-items="ViewBag.ProductId">
                                            <option value="">Select a product...</option>
                                        </select>
                                        <span asp-validation-for="Comment.ProductId" class="text-danger small"></span>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <input type="hidden" asp-for="Comment.ProductId" />
                                <input type="hidden" asp-for="Comment.UserId" value="1" />
                            }
                        </div>

                        @if (!isReply)
                        {
                            <div class="mb-4">
                                <label class="form-label fw-semibold">
                                    <i class="fas fa-reply me-2"></i>Parent Comment (Optional)
                                </label>
                                <select asp-for="Comment.ParentId" class="form-select form-select-lg" asp-items="ViewBag.ParentId">
                                    <option value="">Select a parent comment...</option>
                                </select>
                                <small class="text-muted">Leave empty for a main comment, or select a parent comment for a reply</small>
                                <span asp-validation-for="Comment.ParentId" class="text-danger small"></span>
                            </div>
                        }
                        else
                        {
                            <input type="hidden" asp-for="Comment.ParentId" />
                            <div class="alert alert-info">
                                You are replying to
                                <strong>@Model.ReplyingToUserName</strong>
                               
                            </div>
                        }

                        <div class="mb-4">
                            <label asp-for="Comment.Content" class="form-label fw-semibold">
                                <i class="fas fa-comment me-2"></i>Comment Content
                            </label>
                            <textarea asp-for="Comment.Content" class="form-control" rows="5"
                                      placeholder="Enter your comment or reply..."></textarea>
                            <span asp-validation-for="Comment.Content" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                <i class="fas fa-circle me-2"></i>Status
                            </label>
                            <select asp-for="Comment.StatusId" class="form-select form-select-lg" asp-items="ViewBag.StatusId">
                                <option value="">Select a status...</option>
                            </select>
                            <span asp-validation-for="Comment.StatusId" class="text-danger small"></span>
                        </div>

                        <hr class="my-4">

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-page="Index" class="btn btn-outline-secondary me-md-2">
                                <i class="fas fa-arrow-left me-2"></i>Back to List
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>@(isReply ? "Submit Reply" : "Create Comment")
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
