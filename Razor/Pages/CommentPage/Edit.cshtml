@page
@model Razor.Pages.CommentPage.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Comment</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Comment.Id" />
            <div class="form-group">
                <label asp-for="Comment.UserId" class="control-label"></label>
                <select asp-for="Comment.UserId" class="form-control" asp-items="ViewBag.UserId"></select>
                <span asp-validation-for="Comment.UserId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Comment.ProductId" class="control-label"></label>
                <select asp-for="Comment.ProductId" class="form-control" asp-items="ViewBag.ProductId"></select>
                <span asp-validation-for="Comment.ProductId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Comment.Content" class="control-label"></label>
                <input asp-for="Comment.Content" class="form-control" />
                <span asp-validation-for="Comment.Content" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Comment.CreatedAt" class="control-label"></label>
                <input asp-for="Comment.CreatedAt" class="form-control" />
                <span asp-validation-for="Comment.CreatedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Comment.StatusId" class="control-label"></label>
                <select asp-for="Comment.StatusId" class="form-control" asp-items="ViewBag.StatusId"></select>
                <span asp-validation-for="Comment.StatusId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Comment.ParentId" class="control-label"></label>
                <select asp-for="Comment.ParentId" class="form-control" asp-items="ViewBag.ParentId"></select>
                <span asp-validation-for="Comment.ParentId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
