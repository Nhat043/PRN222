@model MVC.Models.Orders.OrderDetailViewModel

@{
    ViewData["Title"] = "Order Details #" + Model.Id;
}

<h2>@ViewData["Title"]</h2>

<div class="mb-3">
    <strong>Order Date:</strong> @Model.Date.ToString("dd/MM/yyyy HH:mm") <br />
    <strong>Total Price:</strong> @Model.Price.ToString("n0") đ <br />
    <strong>Status:</strong> @Model.StatusName
</div>

<h4>Products</h4>
<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Image</th>
            <th>Product Name</th>
            <th>Quantity</th>
            <th>Price</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.OrderItems)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(item.ProductItem?.Product?.Picture))
                    {
                        <img src="@item.ProductItem.Product.Picture" alt="Product image" width="80" />
                    }
                    else
                    {
                        <span>No image</span>
                    }
                </td>
                <td>@item.ProductItem?.Product?.Name</td>
                <td>@item.Quantity</td>
                <td>@item.Price.ToString("n0") đ</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr>
            <td colspan="3" class="text-end fw-bold">Total:</td>
            <td class="fw-bold">@Model.Price.ToString("n0") đ</td>
        </tr>
    </tfoot>
</table>
