@model MVC.Models.Orders.CheckoutViewModel
@{
    var subtotal = Model.CartItems.Sum(item => (item.SellingPrice ?? 0) * item.Quantity);
    var totalDiscount = Model.CartItems.Sum(item =>
    ((item.SellingPrice ?? 0) * (decimal)(item.Discount ?? 0) / 100) * item.Quantity);
    var total = subtotal - totalDiscount;
}

<div class="container py-5">
    <h2 class="fw-bold mb-4">Order Confirmation</h2>
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    <form asp-action="Checkout" method="post">
        <div class="row">
            <div class="col-lg-8">
                @foreach (var item in Model.CartItems)
                {
                    <div class="card mb-4 shadow-sm">
                        <div class="card-body d-flex align-items-center">
                            <img src="@item.Picture" alt="@item.ProductName" width="100" class="rounded me-4" style="object-fit:cover; height:100px;">
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center mb-2">
                                    <h5 class="fw-bold mb-0">@item.ProductName</h5>
                                    @if (!string.IsNullOrEmpty(item.Ram) || !string.IsNullOrEmpty(item.Rom))
                                    {
                                        <span class="ms-3 text-muted" style="font-size:1.1rem;">
                                            @if (!string.IsNullOrEmpty(item.Ram))
                                            {
                                                <span>@item.Ram</span>
                                            }
                                            @if (!string.IsNullOrEmpty(item.Ram) && !string.IsNullOrEmpty(item.Rom))
                                            {
                                                <span> • </span>
                                            }
                                            @if (!string.IsNullOrEmpty(item.Rom))
                                            {
                                                <span>@item.Rom</span>
                                            }
                                        </span>
                                    }
                                </div>
                                <div class="mb-2">
                                    <span class="me-2">Quantity: <b>@item.Quantity</b></span>
                                </div>
                            </div>
                            <div class="text-end" style="min-width:130px;">
                                <div class="fw-bold fs-5 text-primary">@item.SellingPrice?.ToString("N0") đ</div>
                                <div class="text-danger small">
                                    @if (item.Discount > 0)
                                    {
                                        <span>Discount: @item.Discount?.ToString("N0") %</span>
                                    }
                                </div>
                                <div class="fw-semibold mt-1">Total: @item.TotalPrice.ToString("N0") đ</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="col-lg-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h4 class="fw-bold mb-3">Order Summary</h4>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal</span>
                            <span>@subtotal.ToString("N0") đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Total Discount</span>
                            <span class="text-danger">-@totalDiscount.ToString("N0") đ</span>
                        </div>
                        <div class="d-flex justify-content-between fs-5 fw-bold">
                            <span>Total</span>
                            <span class="text-primary">@total.ToString("N0") đ</span>
                        </div>
                    </div>
                </div>
                <div class="mt-4">
                    <button type="submit" class="btn btn-success px-4 py-2 w-100 fw-bold">Payment Confirmation</button>
                </div>
            </div>
        </div>
    </form>
</div>
