@model DAL.Models.Product
@using MVC.Models.Product
@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    var price = Model.ProductItems.FirstOrDefault()?.SellingPrice ?? 0;
    var accountName = Context.Session.GetString("AccountName");
    var commentVM = ViewBag.CommentVM as CommentViewModel;
    var comments = commentVM?.Comments;
    var currentUserId = commentVM?.CurrentUserId;
    var roleId = Context.Session.GetString("RoleIdSession");
    int? editCommentId = TempData["EditCommentId"] as int?;
    int productId = Model.Id;
    var userId = commentVM?.CurrentUserId;
}

<style>
    .rating input {
        display: none;
    }

    .rating span {
        font-size: 24px;
        color: #ddd;
        cursor: pointer;
    }

    .rating input:checked ~ span {
        color: gold;
    }

    .comment-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 8px;
    }
</style>

<div class="container mt-5">
    <div class="row">
        <div class="col-md-5 text-center">
            <img src="@Model.Picture" alt="@Model.Name" class="img-fluid rounded shadow" />
        </div>

        <div class="col-md-7">
            <h2 class="fw-bold">@Model.Name</h2>
            <h4 id="displayPrice" class="text-secondary mb-3">@price.ToString("N0") VND</h4>

            <form class="add-to-cart-form" asp-controller="Cart" asp-action="AddToCart" method="post">
                <input type="hidden" name="productId" value="@Model.Id" />
                <p class="fw-semibold">Select Option:</p>
                <div class="d-flex flex-wrap gap-3 mb-4">
                    @foreach (var item in Model.ProductItems)
                    {
                        var optionText = string.Join("<br/>", item.VariationOptions.Select(v => $"{v.Variation?.Name}: {v.Value}"));
                        <div class="form-check form-check-inline">
                            <input class="btn-check" type="radio" name="productItemId" id="option-@item.Id" value="@item.Id" data-price="@item.SellingPrice" autocomplete="off" />
                            <label class="btn btn-outline-primary px-4 py-3 text-start" for="option-@item.Id">
                                @Html.Raw(optionText)
                            </label>
                        </div>
                    }
                </div>
                <button type="submit" class="btn btn-danger me-2" id="addToCartBtn" disabled>AddToCart</button>
            </form>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-12">
            <h5>Description</h5>
            <p>@Model.Description</p>
        </div>
    </div>

    <hr class="my-5" />

    <!-- Rating -->
    <div class="rating-container mt-4">
        <h5 class="mb-3 mt-5">Rating</h5>
        @if (!string.IsNullOrEmpty(accountName))
        {
            <form method="post" asp-action="Rate" asp-controller="Product">
                <input type="hidden" name="productId" value="@Model.Id" />
                <div class="rating">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <label>
                            <input type="radio" name="ratingValue" value="@i" onclick="this.form.submit();" />
                            <span>&#9733;</span>
                        </label>
                    }
                </div>
            </form>
        }
        else
        {
            <p class="text-muted">You must <a asp-controller="Auth" asp-action="Login">log in</a> to rate this product.</p>
        }

        <div>
            <span>Average: @ViewBag.AvgRating.ToString("0.0") / 5</span>
        </div>
    </div>

    <!-- Comments -->
    <h5 class="mb-3 mt-5">Comments</h5>

    @if (comments != null && comments.Count > 0)
    {
        @foreach (var parent in comments.Where(c => c.ParentId == null))
        {
            <div class="border p-3 mb-3 rounded">
                <p class="fw-semibold mb-1">
                    <i class="fas fa-user text-primary"></i> @parent.User?.Name
                    <small class="text-muted">(@parent.CreatedAt.ToShortDateString())</small>
                </p>

                <p class="mb-2">@parent.Content</p>

                <div class="comment-actions">
                    @if (userId == parent.UserId || roleId == "1")
                    {
                        <form method="post" asp-action="EditTrigger">
                            <input type="hidden" name="commentId" value="@parent.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-primary">Edit</button>
                        </form>
                        <form method="post" asp-action="HideComment">
                            <input type="hidden" name="commentId" value="@parent.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    }

                    @if (!string.IsNullOrEmpty(accountName))
                    {
                        <button class="btn btn-sm btn-outline-secondary" type="button" onclick="toggleReplyForm(@parent.Id)">Reply</button>
                    }
                </div>

                <!-- Reply Form (toggle) -->
                <form method="post" asp-action="PostComment" class="mt-2 d-none" id="reply-form-@parent.Id">
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <input type="hidden" name="parentId" value="@parent.Id" />
                    <div class="mb-2">
                        <textarea name="content" class="form-control" rows="2" placeholder="Write your reply..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-sm btn-primary">Submit Reply</button>
                </form>

                <!-- Replies -->
                @foreach (var reply in comments.Where(c => c.ParentId == parent.Id).OrderBy(r => r.CreatedAt))
                {
                    <div class="border-start ps-3 ms-3 mt-2">
                        <p class="mb-1 fw-semibold">
                            <i class="fas fa-reply text-secondary"></i> @reply.User?.Name
                            <small class="text-muted">(@reply.CreatedAt.ToShortDateString())</small>
                        </p>
                        <p>@reply.Content</p>
                    </div>
                }
            </div>
        }
    }
    else
    {
        <p>No comments yet.</p>
    }

    @if (!string.IsNullOrEmpty(accountName))
    {
        <form method="post" asp-action="PostComment" class="mt-4">
            <input type="hidden" name="productId" value="@productId" />
            <div class="mb-3">
                <textarea name="content" class="form-control" rows="3" placeholder="Add your comment..."></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Submit</button>
        </form>
    }
    else
    {
        <p class="text-muted mt-4">You must <a asp-controller="Auth" asp-action="Login">log in</a> to post a comment.</p>
    }
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@section Scripts {
    <script>
        function toggleReplyForm(commentId) {
            const form = document.getElementById('reply-form-' + commentId);
            if (form) {
                form.classList.toggle('d-none');
            }
        }

        document.querySelectorAll('input[name="productItemId"]').forEach(radio => {
            radio.addEventListener('change', function () {
                const selectedPrice = this.getAttribute('data-price');
                document.getElementById('displayPrice').innerText = parseInt(selectedPrice).toLocaleString() + ' VND';
            });
        });

        document.addEventListener('DOMContentLoaded', function () {
            const radios = document.querySelectorAll('input[name="productItemId"]');
            const addBtn = document.getElementById('addToCartBtn');
            radios.forEach(radio => {
                radio.addEventListener('change', function () {
                    addBtn.disabled = false;
                });
            });
        });
    </script>
}
